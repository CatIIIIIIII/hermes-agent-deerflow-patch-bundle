+def _merge_default_mcp_servers(profile_dir: Path) -> None:
+    """Merge default-profile MCP servers into a named profile config."""
+    default_home = _get_default_hermes_home()
+    if profile_dir == default_home:
+        return
+
+    source_config_path = default_home / "config.yaml"
+    if not source_config_path.exists():
+        return
+
+    try:
+        with open(source_config_path, "r", encoding="utf-8") as f:
+            source_config = yaml.safe_load(f) or {}
+    except Exception:
+        return
+
+    source_servers = source_config.get("mcp_servers")
+    if not isinstance(source_servers, dict) or not source_servers:
+        return
+
+    target_config_path = profile_dir / "config.yaml"
+    if target_config_path.exists():
+        try:
+            with open(target_config_path, "r", encoding="utf-8") as f:
+                target_config = yaml.safe_load(f) or {}
+        except Exception:
+            return
+    else:
+        target_config = {}
+
+    target_servers = target_config.get("mcp_servers")
+    if target_servers is None:
+        target_servers = {}
+    if not isinstance(target_servers, dict):
+        return
+
+    changed = False
+    for server_name, server_cfg in source_servers.items():
+        if server_name not in target_servers:
+            target_servers[server_name] = server_cfg
+            changed = True
+
+    if not changed:
+        return
+
+    target_config["mcp_servers"] = target_servers
+    with open(target_config_path, "w", encoding="utf-8") as f:
+        yaml.safe_dump(target_config, f, sort_keys=False)
+
+
 # ---------------------------------------------------------------------------
 # CRUD operations
 # ---------------------------------------------------------------------------
@@ -460,6 +511,8 @@ def create_profile(
         except Exception:
             pass  # best-effort — don't fail profile creation over this
 
+    _merge_default_mcp_servers(profile_dir)
+
     return profile_dir
 
 
